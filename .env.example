# Discord Bot Token (required)
DISCORD_TOKEN=your_bot_token_here

# Channel ID for reminders (optional)
REMINDER_CHANNEL_ID=123456789012345678

# Database path (optional)
# Use /app/data/typer.db on Railway with a persistent volume
# Default: typer.db (local file, will be lost on redeploy)
DB_PATH=typer.db

# Timezone (default: Europe/Warsaw)
TZ=Europe/Warsaw