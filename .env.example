# Discord Bot Token (required)
DISCORD_TOKEN=your_bot_token_here

# Logging (optional)
# Levels: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Channel ID for reminders (optional)
REMINDER_CHANNEL_ID=123456789012345678

# Database path (optional)
# Railway: /app/data/typer.db (must use persistent volume)
# Local: typer.db
DB_PATH=/app/data/typer.db

# Timezone (default: Europe/Warsaw)
TZ=Europe/Warsaw

# Archive import (optional)
# Set to true to auto-import .sql files from archive/ folder on first database init
IMPORT_ARCHIVE=false
